{
  "version": 2,
  "redirects": [
    {
      "source": "/rules/canvas.html",
      "destination": "/canvas.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/JeuCanvas/(.*)",
      "destination": "/JeuCanvas/$1"
    },
    {
      "source": "/GamesOnWeb/(.*)",
      "destination": "/GamesOnWeb/$1"
    },
    {
      "source": "/((?!api|JeuCanvas|GamesOnWeb).*)",
      "destination": "/frontend/$1"
    }
  ]
}
